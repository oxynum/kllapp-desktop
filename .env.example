# kllapp Desktop — Environment Variables
# Copy this to kllapp/.env.local after running npm run setup

# ============================================================
# MODE: Choose one
# ============================================================

# --- Mode 1: Offline (default) ---
# Uses PGlite (embedded PostgreSQL) — no internet needed.
# Data stored in ~/Library/Application Support/kllapp/pgdata/

# --- Mode 2: Remote PostgreSQL ---
# Connect to your existing kllapp server database.
# Uncomment and set your connection string:
# POSTGRES_URL=postgresql://user:password@host:5432/kllapp

# Your email on the remote kllapp instance (to log in as your account):
# KLLAPP_USER_EMAIL=you@example.com

# ============================================================
# OPTIONAL
# ============================================================

# AI Assistant (add your Anthropic API key to enable Corinne)
# ANTHROPIC_API_KEY=sk-ant-...
